{
  "manifest_version": 3,
  "name": "Per-Domain Timezone Spoofer",
  "version": "1.0.0",
  "description": "Force a chosen timezone on specific domains (and their subdomains) by overriding the page's JS Date/Intl APIs.",
  "permissions": ["storage", "tabs", "userScripts"],
  "host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "Timezone Spoofer (open options)",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
